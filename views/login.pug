extends base

block content
  main.main
    .login-container
      .login-banner
        .login-logo
          img(src='/img/logo-white.png' alt='Natours logo')
        h1.login-banner__title Welcome back
        p.login-banner__sub Log in to continue your adventure

      .login-body
        form.form.form--login
          .form__group
            label.form__label(for='email') Email address
            input#email.form__input(type='email' placeholder='you@example.com' required)
          .form__group
            label.form__label(for='password') Password
            input#password.form__input(type='password' placeholder='••••••••' required minlength='8')
          .form__forgot
            a(href='/forgot-password') Forgot password?
          .form__group
            button.btn-login(type='submit') Log in

        .login-footer
          | Don't have an account?&nbsp;
          a(href='/signup') Sign up for free
