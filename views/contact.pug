extends base

block content
  main.main

    .contact-page
      //- LEFT — info panel
      .contact-info
        .contact-info__inner
          h1.contact-info__title Get in touch
          p.contact-info__sub
            | Have a question about a tour, need help booking, or just want to say hello?
            | We'd love to hear from you.

          .contact-detail
            .contact-detail__icon
              svg(viewBox='0 0 24 24')
                path(d='M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z' fill='currentColor')
            .contact-detail__text
              span.contact-detail__label Email
              a.contact-detail__value(href='mailto:hello@natours.io') hello@natours.io

          .contact-detail
            .contact-detail__icon
              svg(viewBox='0 0 24 24')
                path(d='M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z' fill='currentColor')
            .contact-detail__text
              span.contact-detail__label Phone
              span.contact-detail__value +1 (800) 628-6877

          .contact-detail
            .contact-detail__icon
              svg(viewBox='0 0 24 24')
                path(d='M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z' fill='currentColor')
            .contact-detail__text
              span.contact-detail__label Address
              span.contact-detail__value 128 Adventure Ave, San Francisco, CA

          .contact-detail
            .contact-detail__icon
              svg(viewBox='0 0 24 24')
                path(d='M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z' fill='currentColor')
            .contact-detail__text
              span.contact-detail__label Hours
              span.contact-detail__value Mon – Fri, 9am – 6pm PST

      //- RIGHT — form
      .contact-form-wrap
        form.form.contact-form
          h2.heading-secondary.ma-bt-lg Send us a message

          .form__group
            label.form__label(for='contact-name') Full name
            input#contact-name.form__input(type='text' placeholder='John Doe' required)

          .form__group
            label.form__label(for='contact-email') Email address
            input#contact-email.form__input(type='email' placeholder='you@example.com' required)

          .form__group
            label.form__label(for='contact-subject') Subject
            select#contact-subject.form__input(required)
              option(value='' disabled selected) Choose a topic…
              option(value='booking') Booking enquiry
              option(value='tour') Tour information
              option(value='payment') Payment issue
              option(value='feedback') Feedback
              option(value='other') Other

          .form__group
            label.form__label(for='contact-message') Message
            textarea#contact-message.form__input.form__textarea(rows='5' placeholder='Tell us how we can help…' required)

          .form__group
            button.btn-login(type='submit') Send message
