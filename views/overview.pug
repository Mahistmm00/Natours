extends base

block content
  //- HERO BANNER
  .hero
    h1.hero__title
      | Discover the World's&nbsp;
      em Hidden Wonders
    p.hero__sub Expert-guided adventures that push your limits and fill your soul
    .hero__stats
      .hero__stat
        .hero__stat-num 9
        .hero__stat-label Tours
      .hero__stat
        .hero__stat-num 1k+
        .hero__stat-label Adventurers
      .hero__stat
        .hero__stat-num 4.9★
        .hero__stat-label Avg Rating
      .hero__stat
        .hero__stat-num 12
        .hero__stat-label Countries

  main.main
    h2.section-title All Tours
    p.section-sub Find your perfect adventure — from gentle hikes to extreme expeditions

    //- .filter-bar
    //-   button.filter-pill.active All
    //-   button.filter-pill Easy
    //-   button.filter-pill Medium
    //-   button.filter-pill Difficult
    //-   button.filter-pill Under $500
    //-   button.filter-pill Bestsellers

    .card-container
      each tour in tours
        article.card
          .card__header
            .card__picture
              .card__picture-overlay
              img.card__picture-img(src=`/img/tours/${tour.imageCover}` alt=`${tour.name}`)
              span.card__badge(class=`card__badge--${tour.difficulty}`)= tour.difficulty
            h3.heading-tertirary= tour.name

          .card__details
            h4.card__sub-heading= `${tour.difficulty} ${tour.duration}-day tour`
            p.card__text= tour.summary
            .card__data
              svg.card__icon
                use(xlink:href='/img/icons.svg#icon-map-pin')
              span= tour.startLocation.description
            .card__data
              svg.card__icon
                use(xlink:href='/img/icons.svg#icon-calendar')
              span= tour.startDates[0].toLocaleString('en-us', {month: 'long', year: 'numeric'})
            .card__data
              svg.card__icon
                use(xlink:href='/img/icons.svg#icon-flag')
              span= `${tour.locations.length} stops`
            .card__data
              svg.card__icon
                use(xlink:href='/img/icons.svg#icon-user')
              span= `${tour.maxGroupSize} people`

          .card__footer
            .card__price-group
              span.card__footer-value= `$${tour.price}`
              span.card__footer-text per person
            .card__rating
              span.card__rating-star ★
              strong= tour.ratingsAverage
              span.card__rating-count= `(${tour.ratingsQuantity})`
            a.btn.btn--green(href=`/tour/${tour.slug}`) Details →
