header.header
  nav.nav.nav--tours
    a.nav__el(href='/') All tours

  .header__logo
    img(src='/img/logo-white.png' alt='Natours logo')

  nav.nav.nav--user
    if user
      button.nav__el.nav__el--logout Log out
      a.nav__el(href='/me')
        img.nav__user-img(src=`/img/users/${user.photo}` alt=`Photo of ${user.name}`)
        span= user.name.split(' ')[0]
    else
      a.nav__el(href='/login') Log in
      a.nav__el.nav__el--cta(href='/signup') Sign up

  button.hamburger#hamburger(aria-label='Open menu' aria-expanded='false')
    span
    span
    span

//- Mobile nav overlay
nav.mobile-nav#mobileNav(aria-hidden='true')
  button.mobile-nav__close#mobileClose(aria-label='Close menu') ✕
  if user
    a.nav__el(href='/') All tours
    a.nav__el(href='/my-tours') My bookings
    a.nav__el(href='/me') My account
    button.nav__el.nav__el--logout Log out
  else
    a.nav__el(href='/') All tours
    a.nav__el(href='/login') Log in
    a.nav__el.nav__el--cta(href='/signup') Sign up
